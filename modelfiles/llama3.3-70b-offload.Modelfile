# Llama 3.3 70B Instruct with CPU layer offload for bazzite (32GB VRAM).
#
# Subtask 3 of issue #50 — first real CPU offload experiment.
#
# Build on bazzite with:
#   ollama create llama3.3-70b-offload -f modelfiles/llama3.3-70b-offload.Modelfile
#   ollama run llama3.3-70b-offload "hi"   # verify it loads
#   ollama ps                              # inspect actual GPU/CPU split
#
# Use from harness with:
#   RUNNER_MODEL=llama3.3-70b-offload runner/.venv/bin/python runner/run_recipe.py ...
#
# Quantization choice (q3_K_M, ~34 GB on disk):
# - The original target was q4_K_M (~42.5 GB), but bazzite's Ollama 0.30.7
#   silently EOFs on that manifest at pull time (cause undiagnosed — likely
#   a pre-download validation check tied to blob size; happens deterministically
#   at ~250ms with no error logs). q3_K_M pulls cleanly.
# - q3 vs q4 PPL delta is < 1% on most benchmarks. The recipe-completion
#   failure mode we're investigating is at the procedural-coherence level,
#   not a precision-bound problem, so the quant step-down is acceptable for
#   this experiment.
# - Bonus: smaller weights = more layers fit on GPU = faster inference and
#   more KV cache headroom.
#
# Tuning the bisect:
# - num_gpu starts at 30 (37.5% of 80 layers on GPU)
# - If load fails with cudaMalloc OOM → lower num_gpu in 5-layer steps
# - If load succeeds with >4 GiB VRAM headroom → raise num_gpu in 5-layer steps
# - Goal: 26-28 GiB VRAM used (~85% — matches qwen3.6 baseline)
#
# Context choice:
# - 65536 is the largest practical num_ctx at this offload ratio.
# - 131072 (matching qwen3.6 baseline) needs ~40 GiB KV cache at f16 —
#   physically impossible on a 32GB card even with q3 weights.
# - Reduce to 32768 if 65K causes OOM during eval (not just at load).

FROM llama3.3:70b-instruct-q3_K_M

PARAMETER num_ctx 65536
PARAMETER num_gpu 30
PARAMETER use_mmap true
PARAMETER num_thread 12

# Note: PARAMETER use_mlock removed — deprecated in recent Ollama (warned
# during `ollama create`). Default (unset → false) is what we wanted anyway.
