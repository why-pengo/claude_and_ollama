    content: """Hydration schemas for the hydration analytics endpoints."""

from datetime import date

from pydantic import BaseModel


class HydrationDaily(BaseModel):
    """A single-row per-day hydration shape: water + 4 electrolytes merged together."""

    date: date
    water_oz: float | None  # mL → fl oz conversion applied where data exists
    sodium_mg: int | None
    potassium_mg: int | None
    calcium_mg: int | None
    magnesium_mg: int | None

    model_config = {"from_attributes": True}


