    content: import math
from datetime import date

from sqlalchemy.ext.asyncio import AsyncSession

from app.schemas.analyticshydration import HydrationDaily
from app.services.analyticshydration import get_daily_series


_AZ = 29.5735  # mL per fluid ounce


async def get_hydration_daily(
    session: AsyncSession,
    date_from: date | None = None,
    date_to: date | None = None,
) -> list[HydrationDaily]:
    """Return one row per date covering all 5 hydration metrics.

    Reuses ``get_daily_series`` for each of the 5 type keys,
    indexes by date, merges, and converts mL → fl-oz for water.
    """
    type_keys = [
        "dietary_water",
        "sodium",
        "potassium",
        "calcium",
        "magnesium",
    ]

    # Fetch all 5 series in parallel
    series_map: dict[str, list] = {}
    for tk in type_keys:
        summary_list = await get_daily_series(session, tk, date_from, date_to, include_sum=True)
        series_map[tk] = {s.date.isoformat(): s for s in summary_list}

    # Collect all dates across all metrics
    all_dates: set[str] = set()
    for s in series_map.values():
        all_dates.update(s.keys())

    if not all_dates:
        return []

    water_entries = series_map.pop("dietary_water")
    merged: list[HydrationDaily] = []
    for day_str in sorted(all_dates):
        date_obj = date.fromisoformat(day_str)

        # water_oz: mL → fl-oz, rounded to 1dp
        water_val = water_entries.get(day_str)
        water_oz: float | None = None
        if water_val is not None and water_val.sum_value is not None:
            water_oz = round(water_val.sum_value / _AZ, 1)

        def _mg_sum(tk: str) -> int | None:
            entry = series_map.get(tk, {}).get(day_str)
            if entry is not None and entry.sum_value is not None:
                return round(entry.sum_value)
            return None

        merged.append(
            HydrationDaily(
                date=date_obj,
                water_oz=water_oz,
                sodium_mg=_mg_sum("sodium"),
                potassium_mg=_mg_sum("potassium"),
                calcium_mg=_mg_sum("calcium"),
                magnesium_mg=_mg_sum("magnesium"),
            )
        )

    return merged

