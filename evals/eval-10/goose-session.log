from httpx import AsyncClient
from sqlalchemy.ext.asyncio import AsyncSession

from app.models.record import HealthRecord
from datetime import datetime, UTC


def _hydration(
    date_str: str,
    type_: str,
    value: float,
    unit: str = "mL",
):
    return HealthRecord(
        owner_id="test_user",
        type=type_,
        value=value,
        unit=unit,
        start_dt=f"{date_str}T08:00:00+00:00",
        imported_at=datetime.now(UTC),
    )


# ---------- auth ----------


@pytest.mark.asyncio
async def test_daily_requires_auth(client: AsyncClient):
    resp = await client.get("/api/hydration/daily")
    assert resp.status_code == 401


@pytest.mark.asyncio
async def test_daily_returns_empty_when_no_rows(
    authenticated_client: AsyncClient,
):
    resp = await authenticated_client.get("/api/hydration/daily")
    assert resp.status_code == 200
    assert resp.json() == []


# ---------- aggregation across 5 metrics ----------


@pytest.mark.asyncio
async def test_daily_aggregates_all_five_metrics(
    authenticated_client: AsyncClient, db_session: AsyncSession,
):
    db_session.add_all(
        [
            _hydration("2025-06-08", "dietary_water", 1500.0, "mL"),
            _hydration("2025-06-08", "sodium", 2000.0, "mg"),
            _hydration("2025-06-08", "potassium", 3000.0, "mg"),
            _hydration("2025-06-08", "calcium", 900.0, "mg"),
            _hydration("2025-06-08", "magnesium", 350.0, "mg"),
        ]
    )
    await db_session.commit()

    resp = await authenticated_client.get("/api/hydration/daily")
    assert resp.status_code == 200
    data = resp.json()
    assert len(data) == 1
    assert data[0]["date"] == "2025-06-08"
    # water_oz = 1500 / 29.5735 ≈ 50.7
    assert data[0]["water_oz"] == pytest.approx(50.7, abs=0.1)
    assert data[0]["sodium_mg"] == 2000
    assert data[0]["potassium_mg"] == 3000
    assert data[0]["calcium_mg"] == 900
    assert data[0]["magnesium_mg"] == 350


@pytest.mark.asyncio
async def test_daily_multiple_records_same_day_aggregate(
    authenticated_client: AsyncClient, db_session: AsyncSession,
):
    # Two water entries on same day → mean is returned.
    db_session.add_all(
        [
            _hydration("2025-06-08", "dietary_water", 1000.0, "mL"),
            _hydration("2025-06-08", "dietary_water", 500.0, "mL"),
            _hydration("2025-06-08", "sodium", 2000.0, "mg"),
            _hydration("2025-06-08", "potassium", 3000.0, "mg"),
            _hydration("2025-06-08", "calcium", 900.0, "mg"),
            _hydration("2025-06-08", "magnesium", 350.0, "mg"),
        ]
    )
    await db_session.commit()

    resp = await authenticated_client.get("/api/hydration/daily")
    data = resp.json()
    # daily_series uses mean → avg water = (1000+500)/2 = 750 mL → 25.3 oz
    assert len(data) == 1
    assert data[0]["water_oz"] == pytest.approx(750 / 29.5735, abs=0.1)


# ---------- date filtering ----------


@pytest.mark.asyncio
async def test_daily_filters_by_date_range(
    authenticated_client: AsyncClient, db_session: AsyncSession,
):
    db_session.add_all(
        [
            _hydration("2025-06-01", "dietary_water", 1500.0, "mL"),
            _hydration("2025-06-08", "dietary_water", 1200.0, "mL"),
            _hydration("2025-06-15", "dietary_water", 900.0, "mL"),
        ]
    )
    await db_session.commit()

    resp = await authenticated_client.get(
        "/api/hydration/daily", params={"from": "2025-06-05", "to": "2025-06-10"}
    )
    data = resp.json()
    assert resp.status_code == 200
    assert len(data) == 1
    assert data[0]["date"] == "2025-06-08"


@pytest.mark.asyncio
async def test_daily_returns_multiple_days(
    authenticated_client: AsyncClient, db_session: AsyncSession,
):
    db_session.add_all(
        [
            _hydration("2025-06-01", "dietary_water", 1500.0, "mL"),
            _hydration("2025-06-02", "dietary_water", 1200.0, "mL"),
            _hydration("2025-06-03", "dietary_water", 900.0, "mL"),
        ]
    )
    await db_session.commit()

    resp = await authenticated_client.get("/api/hydration/daily")
    data = resp.json()
    assert len(data) == 3
    dates = [d["date"] for d in data]
    assert dates == ["2025-06-01", "2025-06-02", "2025-06-03"]


# ---------- mL → fl-oz conversion ----------


@pytest.mark.asyncio
async def test_daily_water_ml_to_oz_conversion(
    authenticated_client: AsyncClient, db_session: AsyncSession,
):
    db_session.add(_hydration("2025-06-08", "dietary_water", 1892.71, "mL"))
    await db_session.commit()

    resp = await authenticated_client.get("/api/hydration/daily")
    data = resp.json()
    # 1892.71 / 29.5735 = 64.0
    assert len(data) == 1
    assert data[0]["water_oz"] == pytest.approx(64.0, abs=0.1)


@pytest.mark.asyncio
async def test_daily_water_oz_rounded_to_1dp(
    authenticated_client: AsyncClient, db_session: AsyncSession,
):
    # A value that produces a non-terminating decimal
    db_session.add(_hydration("2025-06-08", "dietary_water", 1000.0, "mL"))
    expected = round(1000 / 29.5735, 1)
    await db_session.commit()

    resp = await authenticated_client.get("/api/hydration/daily")
    data = resp.json()
    assert len(data) == 1
    assert round(data[0]["water_oz"], 1) == expected


# ---------- missing metric → null, not 0 ----------


@pytest.mark.asyncio
async def test_daily_missing_metrics_are_null(
    authenticated_client: AsyncClient, db_session: AsyncSession,
):
    # Only water, other four metrics absent
    db_session.add(_hydration("2025-06-08", "dietary_water", 1500.0, "mL"))
    await db_session.commit()

    resp = await authenticated_client.get("/api/hydration/daily")
    data = resp.json()
    assert len(data) == 1
    assert data[0]["water_oz"] is not None  # 1500 mL → some oz
    assert data[0]["sodium_mg"] is None
    assert data[0]["potassium_mg"] is None
    assert data[0]["calcium_mg"] is None
    assert data[0]["magnesium_mg"] is None


@pytest.mark.asyncio
async def test_daily_only_potassium(
    authenticated_client: AsyncClient, db_session: AsyncSession,
):
    db_session.add(_hydration("2025-06-08", "potassium", 3000.0, "mg"))
    await db_session.commit()

    resp = await authenticated_client.get("/api/hydration/daily")
    data = resp.json()
    assert len(data) == 1
    assert data[0]["water_oz"] is None
    assert data[0]["sodium_mg"] is None
    assert data[0]["potassium_mg"] == 3000
    assert data[0]["calcium_mg"] is None
    assert data[0]["magnesium_mg"] is None


# ---------- ordering ----------


@pytest.mark.asyncio
async def test_daily_sorted_ascending_by_date(
    authenticated_client: AsyncClient, db_session: AsyncSession,
):
    db_session.add_all(
        [
            _hydration("2025-06-08", "dietary_water", 1500.0, "mL"),
            _hydration("2025-06-01", "dietary_water", 1200.0, "mL"),
            _hydration("2025-06-15", "dietary_water", 900.0, "mL"),
        ]
    )
    await db_session.commit()

    resp = await authenticated_client.get("/api/hydration/daily")
    data = resp.json()
    dates = [d["date"] for d in data]
    assert dates == sorted(dates)


# ---------- non-water metrics (no unit conversion) ----------


@pytest.mark.asyncio
async def test_daily_sodium_sum_across_multiple_records_same_type_same_day(
    authenticated_client: AsyncClient, db_session: AsyncSession,
):
    # Multiple sodium records same day → total should still be 2000
    # (only one per day expected, but let's cover both)
    db_session.add_all(
        [
            _hydration("2025-06-08", "sodium", 1000.0, "mg"),
            _hydration("2025-06-08", "sodium", 1000.0, "mg"),
        ]
    )
    await db_session.commit()

    resp = await authenticated_client.get("/api/hydration/daily")
    data = resp.json()
    # daily_series uses mean → avg sodium = (1000+1000)/2 = 1000
    assert data[0]["sodium_mg"] == 1000


@pytest.mark.asyncio
async def test_daily_potassium_round_to_0dp(
