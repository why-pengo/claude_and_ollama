from pydantic import BaseModel


class HydrationDaily(BaseModel):
    """One row per day covering all 5 hydration metrics."""

    date: date
    water_oz: float | None  # converted from mL via / 29.5735
    sodium_mg: int | None
    potassium_mg: int | None
    calcium_mg: int | None
    magnesium_mg: int | None

