from typing import Annotated

from fastapi import APIRouter, Depends, Query
from sqlalchemy import select
from sqlalchemy.ext.asyncio import AsyncSession

from app.auth import get_current_user
from app.database import get_db
from app.models.hydration_goals import HydrationGoals
from app.schemas.hydration_goals import HydrationGoalsRead, HydrationGoalsUpdate

router = APIRouter(prefix="/api/hydration-goals", tags=["hydration-goals"])


@router.get("/", response_model=HydrationGoalsRead)
async def get_hydration_goals(
    date_from: date | None = Query(None, alias="from"),
    date_to: date | None = Query(None, alias="to"),
    _user: dict = Depends(get_current_user),
    db: Annotated[AsyncSession, Depends(get_db)] = ...,
) -> HydrationGoalsRead:
    """Fetch the user's hydration goals. date_from/date_to params are accepted for API
    consistency with other endpoints but have no effect on goals (which are static)."""
    result = await db.execute(select(HydrationGoals).where(HydrationGoals.id == 1))
    goals = result.scalar_one_or_none()
    if goals is None:
        # Create default goals if none exist
        goals = HydrationGoals(
            id=1,
            water_target_oz=64,
            sodium_target_mg=2300,
            potassium_target_mg=4700,
            calcium_target_mg=1000,
            magnesium_target_mg=400,
        )
        db.add(goals)
        await db.commit()
        await db.refresh(goals)
    return goals


@router.put("/", response_model=HydrationGoalsRead)
async def update_hydration_goals(
    data: HydrationGoalsUpdate,
    _user: dict = Depends(get_current_user),
    db: Annotated[AsyncSession, Depends(get_db)] = ...,
) -> HydrationGoalsRead:
    """Update the user's hydration goals. All fields are optional — only provided fields
    are updated. All provided values are normalised (water oz → int, others → int)."""
    result = await db.execute(select(HydrationGoals).where(HydrationGoals.id == 1))
    goals = result.scalar_one_or_none()
    if goals is None:
        goals = HydrationGoals(id=1)
        db.add(goals)
        await db.commit()
        await db.refresh(goals)

    if data.water_target_oz is not None:
        goals.water_target_oz = int(data.water_target_oz)
    if data.sodium_target_mg is not None:
        goals.sodium_target_mg = int(data.sodium_target_mg)
    if data.potassium_target_mg is not None:
        goals.potassium_target_mg = int(data.potassium_target_mg)
    if data.calcium_target_mg is not None:
        goals.calcium_target_mg = int(data.calcium_target_mg)
    if data.magnesium_target_mg is not None:
        goals.magnesium_target_mg = int(data.magnesium_target_mg)

    goals.updated_at = data.updated_at or goals.updated_at
    await db.commit()
    await db.refresh(goals)
