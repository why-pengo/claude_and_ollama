            content: """
Analytics service - all queries use SQLAlchemy 2.0 select() style.

Date strings follow the HAE format: "2024-11-15 07:42:00 -0500"
SQLite's strftime() returns NULL for timezone-offset strings, so all
date filtering uses substr(col, 1, 10) to extract the YYYY-MM-DD prefix.
Python-side aggregation is used for weekly and morning/evening splits
to avoid complex SQLite-specific date arithmetic.
"""

import asyncio
from collections import defaultdict
from datetime import UTC, date, datetime, timedelta

from sqlalchemy import func, or_, select
from sqlalchemy.ext.asyncio import AsyncSession

from app.models.bp import BPReading
from app.models.medication import Medication
from app.models.record import HealthRecord
from app.models.sleep import SleepRecord
from app.models.workout import Workout
from app.schemas.bp import BPMorningEvening, BPRead, BPStats, BPWeeklyRow
from app.schemas.dashboard import DashboardSummary
from app.schemas.hydration import HydrationDaily
from app.schemas.medication import MedicationRead
from app.schemas.record import DailySummary, RecordType
from app.schemas.sleep import SleepNightly
from app.schemas.workout import WorkoutByActivity, WorkoutRead, WorkoutSummary


def _parse_reading_dt(dt_str: str) -> datetime:
    """Parse HAE date string into a datetime."""
    s = dt_str.strip()
    for i in range(len(s) - 1, 0, -1):
        if s[i - 1] == " " and s[i] in "+-":
            base = s[: i - 1]
            tz = s[i:]
            if len(tz) == 5 and ":" not in tz:
                tz = tz[:3] + ":" + tz[3:]
            return datetime.fromisoformat(f"{base}T{tz}" if "T" not in base else f"{base}{tz}")
    return datetime.fromisoformat(s.replace(" ", "T", 1))


def _date_filters(stmt, date_from: date | None, date_to: date | None):
    if date_from:
        stmt = stmt.where(func.substr(BPReading.reading_dt, 1, 10) >= date_from.isoformat())
    if date_to:
        stmt = stmt.where(func.substr(BPReading.reading_dt, 1, 10) <= date_to.isoformat())
    return stmt


def _safe_avg(values: list[float]) -> float:
    return sum(values) / len(values) if values else 0.0


_HK_LABELS: dict[str, str] = {
    "HKQuantityTypeIdentifierAppleCalcium": "Calcium (Apple)",
    "HKQuantityTypeIdentifierAppleConsumedWater": "Water (Apple)",
    "HKQuantityTypeIdentifierAppleElectrolyte": "Electrolytes (Apple)",
    "HKQuantityTypeIdentifierAppleMagnesium": "Magnesium (Apple)",
    "HKQuantityTypeIdentifierApplePotassium": "Potassium (Apple)",
    "HKQuantityTypeIdentifierAppleSodium": "Sodium (Apple)",
    "HKQuantityTypeIdentifierHeartRate": "Heart Rate",
    "HKQuantityTypeIdentifierRestingHeartRate": "Resting Heart Rate",
    "HKQuantityTypeIdentifierHeartRateVariabilitySDNN": "HRV (SDNN)",
    "HKQuantityTypeIdentifierBodyMass": "Body Weight",
    "HKQuantityTypeIdentifierBodyFatPercentage": "Body Fat %",
    "HKQuantityTypeIdentifierBodyMassIndex": "BMI",
    "HKQuantityTypeIdentifierStepCount": "Steps",
    "HKQuantityTypeIdentifierActiveEnergyBurned": "Active Energy",
    "HKQuantityTypeIdentifierVO2Max": "VO2 Max",
    "HKQuantityTypeIdentifierOxygenSaturation": "Blood Oxygen %",
    "HKQuantityTypeIdentifierRespiratoryRate": "Respiratory Rate",
    "HKQuantityTypeIdentifierAppleSleepingWristTemperature": "Wrist Temp",
    "HKQuantityTypeIdentifierWalkingSpeed": "Walking Speed",
    "HKQuantityTypeIdentifierFlightsClimbed": "Flights Climbed",
    "HKQuantityTypeIdentifierDistanceWalkingRunning": "Distance Walk/Run",
    "HKQuantityTypeIdentifierAppleExerciseTime": "Exercise Time",
    "HKQuantityTypeIdentifierTimeInDaylight": "Time in Daylight",
    "HKQuantityTypeIdentifierEnvironmentalAudioExposure": "Env Audio (dB)",
    "HKQuantityTypeIdentifierHeadphoneAudioExposure": "Headphone Audio (dB)",
    "HKQuantityTypeIdentifierAppleSleepingBreathingDisturbances": "Sleep Breathing Disturbances",
    "sleep_analysis": "Sleep",
}


async def get_bp_stats(
    session: AsyncSession,
    date_from: date | None = None,
    date_to: date | None = None,
) -> BPStats:
    stmt = select(
        func.avg(BPReading.systolic).label("avg_sys"),
        func.avg(BPReading.diastolic).label("avg_dia"),
        func.min(BPReading.systolic).label("min_sys"),
        func.max(BPReading.systolic).label("max_sys"),
        func.min(BPReading.diastolic).label("min_dia"),
        func.max(BPReading.diastolic).label("max_dia"),
        func.count(BPReading.id).label("n_readings"),
    )
    stmt = _date_filters(stmt, date_from, date_to)
    row = (await session.execute(stmt)).one()
    return BPStats(
        avg_sys=round(row.avg_sys or 0.0, 2),
        avg_dia=round(row.avg_dia or 0.0, 2),
        min_sys=row.min_sys or 0.0,
        max_sys=row.max_sys or 0.0,
        min_dia=row.min_dia or 0.0,
        max_dia=row.max_dia or 0.0,
        n_readings=row.n_readings or 0,
    )


async def get_bp_weekly(
    session: AsyncSession,
    date_from: date | None = None,
    date_to: date | None = None,
) -> list[BPWeeklyRow]:
    stmt = select(BPReading).order_by(BPReading.reading_dt)
    stmt = _date_filters(stmt, date_from, date_to)
    readings = (await session.execute(stmt)).scalars().all()
    weeks: dict[date, list[BPReading]] = defaultdict(list)
    for r in readings:
        dt = _parse_reading_dt(r.reading_dt)
        monday = dt.date() - timedelta(days=dt.weekday())
        weeks[monday].append(r)
    return [
        BPWeeklyRow(
            week_of=week_start.isoformat(),
            avg_sys=round(_safe_avg([r.systolic for r in rows]), 2),
            avg_dia=round(_safe_avg([r.diastolic for r in rows]), 2),
            n_readings=len(rows),
        )
        for week_start, rows in sorted(weeks.items())
    ]


async def get_bp_morning_evening(
    session: AsyncSession,
    date_from: date | None = None,
    date_to: date | None = None,
) -> BPMorningEvening:
    stmt = select(BPReading)
    stmt = _date_filters(stmt, date_from, date_to)
    readings = (await session.execute(stmt)).scalars().all()
    morning = [r for r in readings if _parse_reading_dt(r.reading_dt).hour < 12]
    evening = [r for r in readings if _parse_reading_dt(r.reading_dt).hour >= 12]
    return BPMorningEvening(
        morning_sys=round(_safe_avg([r.systolic for r in morning]), 2),
        morning_dia=round(_safe_avg([r.diastolic for r in morning]), 2),
        morning_n=len(morning),
        evening_sys=round(_safe_avg([r.systolic for r in evening]), 2),
        evening_dia=round(_safe_avg([r.diastolic for r in evening]), 2),
        evening_n=len(evening),
    )


async def get_workout_summary(
    session: AsyncSession,
    date_from: date | None = None,
    date_to: date | None = None,
) -> WorkoutSummary:
    stmt = select(Workout)
    if date_from:
        stmt = stmt.where(func.substr(Workout.start_dt, 1, 10) >= date_from.isoformat())
    if date_to:
        stmt = stmt.where(func.substr(Workout.start_dt, 1, 10) <= date_to.isoformat())
    workouts = (await session.execute(stmt)).scalars().all()
    by_activity: dict[str, dict] = defaultdict(
        lambda: {"count": 0, "total_minutes": 0.0, "total_kcal": 0.0}
    )
    total_minutes = 0.0
    total_kcal = 0.0
    for w in workouts:
        key = w.activity or "Unknown"
        by_activity[key]["count"] += 1
        by_activity[key]["total_minutes"] += w.duration_min or 0.0
        by_activity[key]["total_kcal"] += w.energy_kcal or 0.0
        total_minutes += w.duration_min or 0.0
        total_kcal += w.energy_kcal or 0.0
    return WorkoutSummary(
        total_workouts=len(workouts),
        total_minutes=round(total_minutes, 2),
        total_kcal=round(total_kcal, 2),
        by_activity=[
            WorkoutByActivity(
                activity=act,
                count=data["count"],
                total_minutes=round(data["total_minutes"], 2),
                total_kcal=round(data["total_kcal"], 2),
            )
            for act, data in sorted(by_activity.items())
        ],
    )


async def get_hydration_daily(
    session: AsyncSession,
    date_from: date | None = None,
    date_to: date | None = None,
) -> list[HydrationDaily]:
    """Return per-day totals (ml -> oz, electrolytes in mg) for water + Apple Watch nutritional data."""
    water_type = "HKQuantityTypeIdentifierAppleConsumedWater"
    elec_type = "HKQuantityTypeIdentifierAppleElectrolyte"
    na_type = "HKQuantityTypeIdentifierAppleSodium"
    k_type = "HKQuantityTypeIdentifierApplePotassium"
    ca_type = "HKQuantityTypeIdentifierAppleCalcium"
    mg_type = "HKQuantityTypeIdentifierAppleMagnesium"

    types = (water_type, elec_type, na_type, k_type, ca_type, mg_type)
    stmt = select(HealthRecord).where(HealthRecord.type.in_(types))
    if date_from:
        stmt = stmt.where(func.substr(HealthRecord.start_dt, 1, 10) >= date_from.isoformat())
    if date_to:
        stmt = stmt.where(func.substr(HealthRecord.start_dt, 1, 10) <= date_to.isoformat())
    records: list[HealthRecord] = (await session.execute(stmt)).scalars().all()

    by_date: dict[str, dict[str, list[float]]] = defaultdict(
        lambda: {"water_ml": [], "electrolyte_mg": [], "sodium_mg": [],
                 "potassium_mg": [], "calcium_mg": [], "magnesium_mg": []}
    )
    for r in records:
        if r.value is None:
            continue
        day = r.start_dt[:10]
        key = r.type
        if key == water_type:
            by_date[day]["water_ml"].append(r.value)
        elif key == elec_type:
            by_date[day]["electrolyte_mg"].append(r.value)
        elif key == na_type:
            by_date[day]["sodium_mg"].append(r.value)
        elif key == k_type:
            by_date[day]["potassium_mg"].append(r.value)
        elif key == ca_type:
            by_date[day]["calcium_mg"].append(r.value)
        elif key == mg_type:
            by_date[day]["magnesium_mg"].append(r.value)

    result: list[HydrationDaily] = []
    ML_PER_OZ = 29.5735
    for day_str in sorted(by_date.keys()):
        vals = by_date[day_str]
        water_total_ml = sum(vals["water_ml"]) if vals["water_ml"] else 0
        water_total_oz = round(water_total_ml / ML_PER_OZ, 2) if vals["water_ml"] else None
        result.append(
            HydrationDaily(
                date=date.fromisoformat(day_str),
                water_ml=water_total_ml or None,
                water_oz=water_total_oz if water_total_ml else None,
                electrolyte_mg=int(sum(vals["electrolyte_mg"])) if vals["electrolyte_mg"] else None,
                sodium_mg=int(sum(vals["sodium_mg"])) if vals["sodium_mg"] else None,
                potassium_mg=int(sum(vals["potassium_mg"])) if vals["potassium_mg"] else None,
                calcium_mg=int(sum(vals["calcium_mg"])) if vals["calcium_mg"] else None,
                magnesium_mg=int(sum(vals["magnesium_mg"])) if vals["magnesium_mg"] else None,
            )
        )
    return result


async def get_record_types(session: AsyncSession) -> list[RecordType]:
    stmt = (
        select(HealthRecord.type, func.count(HealthRecord.id).label("cnt"), func.max(HealthRecord.unit).label("unit"))
        .group_by(HealthRecord.type)
        .order_by(func.count(HealthRecord.id).desc())
    )
    rows = (await session.execute(stmt)).all()
    types = [
        RecordType(type=row.type, label=_HK_LABELS.get(row.type, row.type), count=row.cnt, unit=row.unit or "")
        for row in rows
    ]
    sleep_count = await session.scalar(select(func.count(SleepRecord.id))) or 0
    if sleep_count:
        types.insert(0, RecordType(type="sleep_analysis", label="Sleep", count=sleep_count, unit="hr"))
    return types


async def get_daily_series(
    session: AsyncSession,
    rec_type: str,
    date_from: date | None = None,
    date_to: date | None = None,
    include_sum: bool = False,
) -> list[DailySummary]:
    if rec_type == "sleep_analysis":
        return await _get_daily_sleep_series(session, date_from, date_to)
    stmt = select(HealthRecord).where(HealthRecord.type == rec_type)
    if date_from:
        stmt = stmt.where(func.substr(HealthRecord.start_dt, 1, 10) >= date_from.isoformat())
    if date_to:
        stmt = stmt.where(func.substr(HealthRecord.start_dt, 1, 10) <= date_to.isoformat())
    records = (await session.execute(stmt)).scalars().all()
    by_date: dict[str, list[float]] = defaultdict(list)
    for r in records:
        if r.value is not None:
            by_date[r.start_dt[:10]].append(r.value)
    result = []
    for day_str, values in sorted(by_date.items()):
        total = sum(values)
        result.append(
            DailySummary(
                date=date.fromisoformat(day_str),
                avg_value=round(total / len(values), 4),
                sum_value=round(total, 4) if include_sum else None,
                min_value=min(values),
                max_value=max(values),
                n=len(values),
            )
        )
    return result


async def _get_daily_sleep_series(
    session: AsyncSession,
    date_from: date | None = None,
    date_to: date | None = None,
) -> list[DailySummary]:
    stmt = select(SleepRecord).where(SleepRecord.total_sleep.is_not(None))
    if date_from:
        stmt = stmt.where(SleepRecord.date >= date_from.isoformat())
    if date_to:
        stmt = stmt.where(SleepRecord.date <= date_to.isoformat())
    records = (await session.execute(stmt)).scalars().all()
    by_date: dict[str, list[tuple[str, float]]] = defaultdict(list)
    for r in records:
        by_date[r.date].append((r.source or "", r.total_sleep))
    result = []
    for day_str, source_values in sorted(by_date.items()):
        ultrahuman = [v for s, v in source_values if "ultrahuman" in s.lower()]
        values = ultrahuman if ultrahuman else [v for _, v in source_values]
        result.append(
            DailySummary(
                date=date.fromisoformat(day_str),
                avg_value=round(sum(values) / len(values), 4),
                min_value=min(values),
                max_value=max(values),
                n=len(values),
            )
        )
    return result


def _in_bed_minutes(start: str | None, end: str | None) -> float | None:
    if not start or not end:
        return None
    try:
        s = datetime.fromisoformat(start)
        e = datetime.fromisoformat(end)
    except ValueError:
        return None
    delta = (e - s).total_seconds() / 60.0
    return round(delta, 4) if delta > 0 else None


def _pick_preferred_sleep_row(rows: list[SleepRecord]) -> SleepRecord:
    ultrahuman = [r for r in rows if r.source and "ultrahuman" in r.source.lower()]
    candidates = ultrahuman if ultrahuman else rows
    return max(candidates, key=lambda r: r.total_sleep or 0.0)


async def get_sleep_nightly(
    session: AsyncSession,
    date_from: date | None = None,
    date_to: date | None = None,
) -> list[SleepNightly]:
    stmt = select(SleepRecord)
    if date_from:
        stmt = stmt.where(SleepRecord.date >= date_from.isoformat())
    if date_to:
        stmt = stmt.where(SleepRecord.date <= date_to.isoformat())
    records = (await session.execute(stmt)).scalars().all()
    by_date: dict[str, list[SleepRecord]] = defaultdict(list)
    for r in records:
        by_date[r.date].append(r)
    result: list[SleepNightly] = []
    for day_str, rows in sorted(by_date.items()):
        row = _pick_preferred_sleep_row(rows)
        in_bed_min = _in_bed_minutes(row.in_bed_start, row.in_bed_end)
        efficiency: float | None = None
        if in_bed_min and row.total_sleep is not None and in_bed_min > 0:
            efficiency = round((row.total_sleep * 60.0) / in_bed_min, 4)
        result.append(
            SleepNightly(
                date=date.fromisoformat(day_str),
                total_sleep=row.total_sleep,
                deep=row.deep,
                rem=row.rem,
                core=row.core,
                awake=row.awake,
                in_bed_minutes=in_bed_min,
                sleep_efficiency=efficiency,
            )
        )
    return result


async def _get_bp_trend(session: AsyncSession) -> str:
    today = datetime.now(UTC).date()
    cutoff_30d = today - timedelta(days=30)
    cutoff_7d = today - timedelta(days=7)
    stmt = select(BPReading).where(func.substr(BPReading.reading_dt, 1, 10) >= cutoff_30d.isoformat())
    readings = (await session.execute(stmt)).scalars().all()
    last_7 = [r.systolic for r in readings if r.reading_dt[:10] >= cutoff_7d.isoformat()]
    prior_23 = [r.systolic for r in readings if r.reading_dt[:10] < cutoff_7d.isoformat()]
    if not last_7 or not prior_23:
        return "stable"
    avg_last = _safe_avg(last_7)
    avg_prior = _safe_avg(prior_23)
    delta = avg_last - avg_prior
    if delta < -3:
        return "improving"
    if delta > 3:
        return "worsening"
    return "stable"


async def _get_active_medications(session: AsyncSession) -> list[MedicationRead]:
    today = datetime.now(UTC).date().isoformat()
    stmt = select(Medication).where(or_(Medication.end_date.is_(None), Medication.end_date >= today)).order_by(Medication.start_date)
    meds = (await session.execute(stmt)).scalars().all()
    return [MedicationRead.model_validate(m) for m in meds]


async def _get_last_workout(session: AsyncSession) -> WorkoutRead | None:
    w = (await session.execute(select(Workout).order_by(Workout.start_dt.desc()).limit(1))).scalar_one_or_none()
    return WorkoutRead.model_validate(w) if w else None


async def _get_steps_7d(session: AsyncSession) -> float | None:
    today = datetime.now(UTC).date().isoformat()
    cutoff = (today - timedelta(days=7))
    stmt = select(func.sum(HealthRecord.value)).where(HealthRecord.type == "step_count").where(func.substr(HealthRecord.start_dt, 1, 10) >= cutoff.isoformat())
    result = (await session.execute(stmt)).scalar_one_or_none()
    return float(result) if result is not None else None


async def _get_latest_bp(session: AsyncSession) -> BPRead | None:
    r = (await session.execute(select(BPReading).order_by(BPReading.reading_dt.desc()).limit(1))).scalar_one_or_none()
    return BPRead.model_validate(r) if r else None


async def get_dashboard_summary(session: AsyncSession) -> DashboardSummary:
    today = datetime.now(UTC).date()
    date_from_30d = today - timedelta(days=30)
    results = await asyncio.gather(
        get_bp_stats(session, date_from=date_from_30d, date_to=today),
        _get_bp_trend(session),
        _get_active_medications(session),
        _get_last_workout(session),
        _get_steps_7d(session),
        _get_latest_bp(session),
        return_exceptions=True,
    )
    def _safe(val, default): return default if isinstance(val, Exception) else val
    bp_30d: BPStats | None = _safe(results[0], None)
    if bp_30d and bp_30d.n_readings == 0:
        bp_30d = None
    return DashboardSummary(
        bp_30d=bp_30d, bp_trend=_safe(results[1], "stable"), active_medications=_safe(results[2], []),
        last_workout=_safe(results[3], None), steps_7d=_safe(results[4], None), latest_bp=_safe(results[5], None),
    )

