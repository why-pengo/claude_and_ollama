from pydantic import BaseModel


class HydrationDaily(BaseModel):
    """One row per date covering all 5 hydration metrics.

    `water_oz` is in fluid ounces (converted from mL stored in HAE data).
    Electrolyte fields are in mg, pass-through from HAE.
    Missing metric on a date → field is `null`, not `0`.
    """

    date: date
    water_oz: float | None
    sodium_mg: int | None
    potassium_mg: int | None
    calcium_mg: int | None
    magnesium_mg: int | None

