    date: str = Field(..., description="Date in YYYY-MM-DD format.")
    water_ml: float | None = Field(None, description="Water volume in mL.  None when no Apple Water data exists for this day.")
    water_oz: float | None = Field(None, description="Water volume converted to ounces.")
    electrolyte_mg: int | None = Field(None, description="Electrolyte intake in mg.")
    sodium_mg: int | None = Field(None, description="Sodium intake in mg.")
    potassium_mg: int | None = Field(None, description="Potassium intake in mg.")
