from fastapi import APIRouter, Depends
from sqlalchemy import select
from sqlalchemy.exc import IntegrityError
from sqlalchemy.ext.asyncio import AsyncSession

from app.auth import get_current_user
from app.database import get_db
from app.models.hydration_goals import HydrationGoals
from app.schemas.hydration_goals import HydrationGoalsRead, HydrationGoalsUpdate

router = APIRouter(prefix="/api/hydration-goals", tags=["hydration-goals"])


# CDC / common recommendations
DEFAULT_WATER_TARGET_OZ = 64
DEFAULT_SODIUM_TARGET_MG = 2300
DEFAULT_POTASSIUM_TARGET_MG = 3400
DEFAULT_CALCIUM_TARGET_MG = 1000
DEFAULT_MAGNESIUM_TARGET_MG = 400


async def _get_or_seed(db: AsyncSession) -> HydrationGoals:
    row = (
        await db.execute(select(HydrationGoals).where(HydrationGoals.id == 1))
    ).scalar_one_or_none()
    if row is not None:
        return row
    row = HydrationGoals(
        id=1,
        water_target_oz=DEFAULT_WATER_TARGET_OZ,
        sodium_target_mg=DEFAULT_SODIUM_TARGET_MG,
        potassium_target_mg=DEFAULT_POTASSIUM_TARGET_MG,
        calcium_target_mg=DEFAULT_CALCIUM_TARGET_MG,
        magnesium_target_mg=DEFAULT_MAGNESIUM_TARGET_MG,
        updated_at=datetime.now(UTC).isoformat(),
    )
    db.add(row)
    try:
        await db.commit()
    except IntegrityError:
        # Concurrent first-read inserted id=1 between our SELECT and COMMIT.
        # Roll back our doomed insert and refetch the winner's row.
        await db.rollback()
        row = (await db.execute(select(HydrationGoals).where(HydrationGoals.id == 1))).scalar_one()
        return row
    await db.refresh(row)
    return row


@router.get("", response_model=HydrationGoalsRead)
async def get_hydration_goals(
    _: dict = Depends(get_current_user),
    db: AsyncSession = Depends(get_db),
) -> HydrationGoalsRead:
    row = await _get_or_seed(db)
    return HydrationGoalsRead.model_validate(row)


@router.put("", response_model=HydrationGoalsRead)
async def update_hydration_goals(
    body: HydrationGoalsUpdate,
    _: dict = Depends(get_current_user),
    db: AsyncSession = Depends(get_db),
) -> HydrationGoalsRead:
    row = await _get_or_seed(db)
    row.water_target_oz = body.water_target_oz
    row.sodium_target_mg = body.sodium_target_mg
    row.potassium_target_mg = body.potassium_target_mg
    row.calcium_target_mg = body.calcium_target_mg
    row.magnesium_target_mg = body.magnesium_target_mg
    row.updated_at = datetime.now(UTC).isoformat()
    await db.commit()
    await db.refresh(row)
    return HydrationGoalsRead.model_validate(row)

