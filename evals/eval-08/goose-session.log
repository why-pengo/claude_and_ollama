        {"water_target_oz": 64, "sodium_target_mg": 2300, "potassium_target_mg": 3400, "calcium_target_mg": 1000, "magnesium_target_mg": 0}
    ]
)
@pytest.mark.asyncio
async def test_put_rejects_negative_values(authenticated_client: AsyncClient, payload):
    resp = await authenticated_client.put("/api/hydration-goals", json=payload)
    assert resp.status_code == 422


@pytest.mark.asyncio
async def test_put_rejects_missing_fields(authenticated_client: AsyncClient):
    resp = await authenticated_client.put(
        "/api/hydration-goals",
        json={"water_target_oz": 64}
    )
    assert resp.status_code == 422


@pytest.mark.asyncio
async def test_get_requires_auth(unauthenticated_client: AsyncClient):
    resp = await unauthenticated_client.get("/api/hydration-goals")
    assert resp.status_code == 401


@pytest.mark.asyncio
async def test_put_requires_auth(unauthenticated_client: AsyncClient):
    resp = await unauthenticated_client.put(
        "/api/hydration-goals",
        json={
            "water_target_oz": 64,
            "sodium_target_mg": 2300,
            "potassium_target_mg": 3400,
            "calcium_target_mg": 1000,
            "magnesium_target_mg": 400
        }
    )
    assert resp.status_code == 401


@pytest.mark.asyncio
async def test_get_or_seed_handles_race(db_session: AsyncSession):
    db_session.add(
        HydrationGoals(
            id=1,
            water_target_oz=999,
            sodium_target_mg=999,
            potassium_target_mg=999,
            calcium_target_mg=999,
            magnesium_target_mg=999,
            updated_at="2026-01-01T00:00:00+00:00"
        )
    )
    await db_session.commit()
    db_session.expunge_all()

    original_execute = db_session.execute
    calls_n = {"n": 0}

    class _NoRowResult:
        def scalar_one_or_none(self):
            return None

    async def fake_execute(stmt, *args, **kwargs):
        calls_n["n"] += 1
        if calls_n["n"] == 1:
            return _NoRowResult()
        return await original_execute(stmt, *args, **kwargs)

    db_session.execute = fake_execute

    row = await _get_or_seed(db_session)
    assert row.water_target_oz == 999
    assert row.sodium_target_mg == 999
    assert row.potassium_target_mg == 999
    assert row.calcium_target_mg == 999
    assert row.magnesium_target_mg == 999

