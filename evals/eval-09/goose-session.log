    content: import type { HydrationDaily, NutrientSemantics, NutrientStatus } from "@/types/hydration";

/**
 * Convert millilitres to US fluid ounces, rounded to 1 decimal place.
 * Uses the standard conversion: 1 fl oz = 29.5735 ml.
 */
export function mlToFlOz(ml: number): number {
  return Math.round((ml / 29.5735) * 10) / 10;
}

/**
 * Classify how the actual intake compares to a target, with semantics
 * that differ for nutrients where "too little" is a concern versus
 * those where only an upper limit matters (e.g. sodium).
 *
 * - "under-bad" (water, K, Ca, Mg): actual below target × 0.9 → "under"
 * - "upper-limit" (sodium): actual above target → "over"; there is
 *   no "under" because not enough sodium is not a concern for this
 *   helper's purpose.
 *
 * A null actual is treated as "under" for under-bad and "on" for
 * upper-limit (absence is compliant with an upper limit).
 */
export function classify(
  actual: number | null | undefined,
  target: number,
  semantics: NutrientSemantics,
): NutrientStatus {
  if (actual == null) {
    if (semantics === "under-bad") return "under";
    return "on";
  }

  if (semantics === "upper-limit") {
    return actual <= target ? "on" : "over";
  }

  // under-bad semantics
  if (actual < target * 0.9) return "under";
  if (actual > target * 1.1) return "over";
  return "on";
}

/**
 * Count consecutive calendar-adjacent days ending at the array's latest
 * date where water_oz hits or exceeds targetOz.
 *
 * A missing row for a date in the sequence breaks the streak (same as
 * a sub-target day).
 */
export function waterGoalStreak(daily: HydrationDaily[], targetOz: number): number {
  if (daily.length === 0) return 0;

  // Sort by date ascending so [0] is oldest and [...-1] is latest.
  const sorted = [...daily].sort((a, b) => a.date.localeCompare(b.date));
  const latest = sorted[sorted.length - 1].date;

  // Build a date → row lookup.
  const map = new Map<string, HydrationDaily>();
  for (const row of sorted) {
    map.set(row.date, row);
  }

  let streak = 0;
  // Start counting from the latest date going backwards.
  const today = new Date(`${latest}T00:00:00`);

  for (let i = 0; ; i++) {
    const d = new Date(today);
    d.setDate(today.getDate() - i);
    const dateStr = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;

    const row = map.get(dateStr);
    if (
      !row ||
      row.water_oz == null ||
      row.water_oz < targetOz
    ) {
      // If we're on day 0 (the latest date) and the target isn't met,
      // the streak is zero — the day itself doesn't count.
      if (i === 0) return 0;
      break;
    }
    streak++;
  }

  return streak;
}

/**
 * Compute a trailing rolling average over non-null values.
 *
 * For each index, average the previous `window` non-null values
 * (including the current index). Returns null if fewer than `window/2`
 * values are available in the window.
 */
export function rollingAverage(
  values: (number | null)[],
  window: number,
): (number | null)[] {
  const result: (number | null)[] = [];
  const halfWindow = Math.floor(window / 2);

  for (let i = 0; i < values.length; i++) {
    const start = Math.max(0, i - window + 1);
    const windowValues: number[] = [];

    for (let j = start; j <= i; j++) {
      if (values[j] != null) {
        windowValues.push(values[j]);
      }
    }

    if (windowValues.length >= halfWindow) {
      const sum = windowValues.reduce((a, b) => a + b, 0);
      result.push(sum / windowValues.length);
    } else {
      result.push(null);
    }
  }

  return result;
}

