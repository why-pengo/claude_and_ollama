    content: import { describe, expect, it } from "vitest";
import type { HydrationDaily } from "@/types/hydration";
import { classify, mlToFlOz, rollingAverage, waterGoalStreak } from "./hydration";

describe("mlToFlOz", () => {
  it("29.5735 ml → 1.0 fl oz", () => {
    expect(mlToFlOz(29.5735)).toBe(1.0);
  });

  it("591.47 ml → 20.0 fl oz", () => {
    expect(mlToFlOz(591.47)).toBe(20.0);
  });

  it("0 ml → 0", () => {
    expect(mlToFlOz(0)).toBe(0);
  });
});

describe("classify — under-bad", () => {
  it("actual 0.89× target → under", () => {
    expect(classify(89, 100, "under-bad")).toBe("under");
  });

  it("actual 0.91× target → on (just above lower bound)", () => {
    expect(classify(91, 100, "under-bad")).toBe("on");
  });

  it("actual 1.09× target → on (just below upper bound)", () => {
    expect(classify(109, 100, "under-bad")).toBe("on");
  });

  it("actual 1.11× target → over", () => {
    expect(classify(111, 100, "under-bad")).toBe("over");
  });

  it("exactly at target → on", () => {
    expect(classify(100, 100, "under-bad")).toBe("on");
  });
});

describe("classify — upper-limit", () => {
  it("at target → on", () => {
    expect(classify(100, 100, "upper-limit")).toBe("on");
  });

  it("just below target → on", () => {
    expect(classify(99, 100, "upper-limit")).toBe("on");
  });

  it("just above target → over", () => {
    expect(classify(101, 100, "upper-limit")).toBe("over");
  });
});

describe("classify — null actual", () => {
  it("null under-bad → under", () => {
    expect(classify(null, 200, "under-bad")).toBe("under");
  });

  it("null upper-limit → on (compliant with upper limit)", () => {
    expect(classify(null, 2300, "upper-limit")).toBe("on");
  });
});

describe("waterGoalStreak", () => {
  function day(date: string, oz: number): HydrationDaily {
    return {
      date,
      water_ml: null,
      water_oz: oz,
      sodium: null,
      potassium: null,
      calcium: null,
      magnesium: null,
    };
  }

  it("3 consecutive hits ending today → streak 3", () => {
    const rows = [
      day("2025-06-06", 28),
      day("2025-06-07", 28),
      day("2025-06-08", 28),
    ];
    expect(waterGoalStreak(rows, 28)).toBe(3);
  });

  it("3 consecutive hits ending yesterday → 0 (last day doesn't hit)", () => {
    const rows = [
      day("2025-06-05", 28),
      day("2025-06-06", 28),
      day("2025-06-07", 28),
    ];
    expect(waterGoalStreak(rows, 28)).toBe(0);
  });

  it("gap day breaks streak", () => {
    const rows = [
      day("2025-06-05", 28),
      day("2025-06-06", 28),
      // 06-07 missing
      day("2025-06-08", 28),
    ];
    expect(waterGoalStreak(rows, 28)).toBe(1);
  });

  it("single-day input, hits target → 1", () => {
    const rows = [day("2025-06-08", 28)];
    expect(waterGoalStreak(rows, 28)).toBe(1);
  });

  it("single-day input, below target → 0", () => {
    const rows = [day("2025-06-08", 20)];
    expect(waterGoalStreak(rows, 28)).toBe(0);
  });
});

describe("rollingAverage", () => {
  it("simple 7-day window", () => {
    // 7 non-null values in a window of 7 → full average.
    const values = [1, 2, 3, 4, 5, 6, 7];
    const result = rollingAverage(values, 7);
    // Last element: average of all 7 = 4
    expect(result[6]).toBe(4);
  });

  it("nulls in window are excluded from the average", () => {
    const values = [10, null, null, 40, null, null, 70];
    const result = rollingAverage(values, 7);
    // Last element: window covers [10, null, null, 40, null, null, 70]
    // Non-null values: [10, 40, 70]; count = 3 >= halfWindow (3) → average = 40
    expect(result[6]).toBe(40);
  });

  it("edges of array: insufficient values return null", () => {
    const values = [10, null, null, null, null, null, null];
    const result = rollingAverage(values, 7);
    // At index 6, only 1 non-null value but halfWindow is 3 → null
    expect(result[6]).toBeNull();
  });

  it("window of 1 returns the value itself (when non-null)", () => {
    const values = [10, 20, 30];
    const result = rollingAverage(values, 1);
    expect(result).toEqual([10, 20, 30]);
  });

  it("all nulls → all nulls", () => {
    const values: (number | null)[] = [null, null, null];
    const result = rollingAverage(values, 3);
    // halfWindow = 1, so even 1 non-null would pass, but there are none.
    expect(result).toEqual([null, null, null]);
  });
});

