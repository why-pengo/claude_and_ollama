async def get_sleep_nightly(
    session: AsyncSession,
    date_from: date | None = None,
    date_to: date | None = None,
) -> list[SleepNightly]:
    """Per-night sleep rows with stage breakdown and derived in-bed/efficiency.

    Applies the same Ultrahuman-preferred dedupe rule as the daily series
    so the page never shows two competing rows for one night.
    """
    stmt = select(SleepRecord)
    if date_from:
        stmt = stmt.where(SleepRecord.date >= date_from.isoformat())
    if date_to:
        stmt = stmt.where(SleepRecord.date <= date_to.isoformat())
    records = (await session.execute(stmt)).scalars().all()

    by_date: dict[str, list[SleepRecord]] = defaultdict(list)
    for r in records:
        by_date[r.date].append(r)

    result: list[SleepNightly] = []
    for day_str, rows in sorted(by_date.items()):
